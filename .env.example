# Metaphors — Environment Variables
# Copy this file to .env and adjust values as needed.

# Server bind address
HOST=0.0.0.0

# Server port
PORT=8000

# Entity refresh interval in seconds
UPDATE_INTERVAL=3.0

# Logging level: debug | info | warning | error
LOG_LEVEL=info

# Prometheus server URL (optional — leave empty to disable Prometheus source)
PROMETHEUS_URL=http://localhost:9090
